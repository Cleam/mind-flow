generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DocumentChunks {
  id        BigInt                @id @default(autoincrement())
  content   String
  metadata  Json
  embedding Unsupported("vector(1536)")
  createdAt DateTime              @default(now())

  @@map("document_chunks")
}
