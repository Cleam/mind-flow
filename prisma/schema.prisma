generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ChatRole {
  user
  assistant
}

model DocumentChunks {
  id        BigInt                @id @default(autoincrement())
  content   String
  metadata  Json
  embedding Unsupported("vector(1536)")
  createdAt DateTime              @default(now())

  @@map("document_chunks")
}

model ChatMessage {
  id        BigInt   @id @default(autoincrement())
  sessionId String
  role      ChatRole
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}
