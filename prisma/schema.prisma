generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DocumentChunk {
  id        BigInt                @id @default(autoincrement())
  content   String
  metadata  Json
  embedding Unsupported("vector")
  createdAt DateTime              @default(now())
}
