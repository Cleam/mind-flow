DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mind_flow?schema=public"
PORT=3300

# LLM Provider: mock | qwen | openai | ollama
EMBEDDING_PROVIDER="mock"

# Qwen 阿里云百炼（当 EMBEDDING_PROVIDER=qwen 时必填）
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_EMBEDDING_MODEL="text-embedding-v4"
QWEN_RERANK_MODEL="gte-rerank"
QWEN_CHAT_MODEL="qwen-plus"

# OpenAI（当 EMBEDDING_PROVIDER=openai 时必填）
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_RERANK_MODEL="rerank-v1"
OPENAI_CHAT_MODEL="gpt-4o-mini"

# Ollama 本地模型（当 EMBEDDING_PROVIDER=ollama 时生效）
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
OLLAMA_RERANK_MODEL="bge-reranker-base"
OLLAMA_CHAT_MODEL="qwen2.5:7b-instruct"
